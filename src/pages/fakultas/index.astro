---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/navbar.astro";
---

<Layout title="Semua Fakultas - UKRIM Feedback">
  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <Navbar />

  <div class="container mx-auto px-6 py-8 mt-10 mb-20">
    <div class="text-center mb-16 space-y-3">
      <h1
        class="text-2xl md:text-3xl font-black text-gray-900 dark:text-white uppercase tracking-widest"
      >
        SEMUA FAKULTAS
      </h1>
      <p class="text-xs text-gray-500 uppercase tracking-[0.2em]">
        DATA REAL-TIME BERDASARKAN ANALISIS AI
      </p>
    </div>

    <div
      class="flex flex-col lg:flex-row items-center justify-center gap-10 lg:gap-20 mb-20 max-w-6xl mx-auto"
    >
      <div
        class="w-full lg:w-auto flex justify-center lg:justify-end order-2 lg:order-1"
      >
        <table
          class="text-xs md:text-sm font-medium text-gray-500 dark:text-gray-400 border-separate border-spacing-y-5"
        >
          <tbody id="global-stats-body">
            <tr>
              <td colspan="3" class="text-center italic text-xs"
                >Sedang menghitung data...</td
              >
            </tr>
          </tbody>
        </table>
      </div>

      <div class="w-full lg:w-1/2 max-w-[600px] order-1 lg:order-2">
        <div
          class="bg-[#0f1219] border border-gray-800 rounded-xl p-4 h-72 relative shadow-2xl flex flex-col justify-center"
        >
          <div class="relative w-full h-full">
            <canvas id="facultyChart"></canvas>
          </div>
        </div>
        <p
          class="text-center text-[10px] text-gray-500 mt-3 uppercase tracking-wider"
        >
          Grafik Tingkat Kepuasan (Sentimen Positif)
        </p>
      </div>
    </div>

    <div class="text-center mb-16 max-w-4xl mx-auto">
      <div
        class="h-px bg-gradient-to-r from-transparent via-gray-700 to-transparent w-full mb-8"
      >
      </div>
      <p
        class="text-[10px] md:text-xs text-gray-400 uppercase tracking-widest mb-4"
      >
        PILIH FAKULTAS UNTUK MELIHAT DETAIL
      </p>
    </div>

    <div
      id="faculty-grid"
      class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-24 max-w-7xl mx-auto px-4"
    >
      <div class="col-span-full flex justify-center py-10">
        <span
          class="inline-block w-8 h-8 border-4 border-blue-500 border-t-transparent rounded-full animate-spin"
        ></span>
      </div>
    </div>
    <div class="text-center mt-20 mb-10 max-w-4xl mx-auto">
      <div
        class="h-px bg-gradient-to-r from-transparent via-gray-700 to-transparent w-full mb-8"
      >
      </div>
      <p
        class="text-[10px] md:text-xs text-gray-400 uppercase tracking-widest mb-2"
      >
        APA KATA MEREKA?
      </p>
      <h2
        class="text-2xl font-black text-gray-900 dark:text-white uppercase tracking-widest"
      >
        SUARA TERBARU
      </h2>
    </div>

    <div
      id="feedback-container"
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 max-w-6xl mx-auto px-4 mb-20"
    >
      <div class="col-span-full text-center py-10">
        <span class="text-gray-500 text-xs italic">Memuat feedback...</span>
      </div>
    </div>
  </div>

  <footer
    class="container mx-auto px-6 py-10 flex flex-col md:flex-row justify-between items-center gap-6 border-t border-gray-200 dark:border-gray-800 mt-auto bg-white dark:bg-[#050505]"
  >
    <div
      class="flex items-center gap-3 opacity-60 hover:opacity-100 transition-opacity"
    >
      <div
        class="w-8 h-8 rounded-full bg-white overflow-hidden border border-gray-200"
      >
        <img
          src="/images/logo-ukrim.jpg"
          alt="Logo"
          class="w-full h-full object-cover"
        />
      </div>
      <span class="text-[10px] font-bold text-gray-500 leading-tight"
        >UNIVERSITAS<br />KRISTEN<br />IMMANUEL</span
      >
    </div>

    <div
      class="flex gap-8 text-[10px] md:text-xs font-bold text-gray-500 tracking-wider"
    >
      <a href="/feedback" class="hover:text-blue-500 transition"
        >BERI FEEDBACK</a
      >
      <a href="/fakultas" class="hover:text-blue-500 transition">FAKULTAS</a>
      <a href="/" class="text-blue-500 transition">HOME</a>
    </div>
  </footer>

 <script is:inline>
    const API_URL = "/api/feedback.json";
    const FACULTY_LIST = ["FEBI", "FAK", "FT", "FISKOM", "FARMASI"];

    async function initDashboard() {
        try {
            const res = await fetch(API_URL);
            if (!res.ok) throw new Error("Gagal fetch data");
            const data = await res.json();
            
            const facultiesData = data.stats?.faculties || {};
            const feedbacks = data.feedbacks || [];

            // 1. STATISTIK GLOBAL
            renderGlobalStats(FACULTY_LIST, facultiesData);

            // 2. CHART
            renderChart(FACULTY_LIST, facultiesData);

            // 3. KARTU FAKULTAS (Grid Rapi)
            renderFacultyCards(FACULTY_LIST, facultiesData);

            // 4. SUARA TERBARU (Baru Ditambahkan)
            renderFeedbackList(feedbacks);

        } catch (error) {
            console.error("Error:", error);
            const grid = document.getElementById("faculty-grid");
            if(grid) grid.innerHTML = `<div class="col-span-full text-red-500 text-center">Gagal memuat data.</div>`;
        }
    }

    // --- LOGIC STATISTIK GLOBAL ---
    function renderGlobalStats(codes, data) {
        let totalFeedback = 0, totalAspekAll = 0, totalPositifAll = 0;
        let bestFaculty = "-", highestPercent = -1;

        codes.forEach(code => {
            const f = data[code] || { count: 0, ai_positif: 0, total_aspek: 0 };
            totalFeedback += f.count;
            totalAspekAll += f.total_aspek;
            totalPositifAll += f.ai_positif;

            const currentPercent = f.total_aspek > 0 ? (f.ai_positif / f.total_aspek) * 100 : 0;
            if (f.count > 0 && currentPercent > highestPercent) {
                highestPercent = currentPercent;
                bestFaculty = code;
            }
        });

        const globalSatisfaction = totalAspekAll > 0 ? Math.round((totalPositifAll / totalAspekAll) * 100) : 0;
        
        const statsBody = document.getElementById("global-stats-body");
        if(statsBody) {
            statsBody.innerHTML = `
                <tr><td class="pr-12 uppercase tracking-wide text-gray-500">TOTAL FEEDBACK</td><td class="px-2 text-center">:</td><td class="text-gray-900 dark:text-white font-bold text-base pl-2">${totalFeedback}</td></tr>
                <tr><td class="pr-12 uppercase tracking-wide text-gray-500">KEPUASAN GLOBAL</td><td class="px-2 text-center">:</td><td class="text-green-500 font-bold text-base pl-2">${globalSatisfaction}% <span class="text-[10px] text-gray-600 font-normal">(Positif)</span></td></tr>
                <tr><td class="pr-12 uppercase tracking-wide text-gray-500">KEPUASAN TERTINGGI</td><td class="px-2 text-center">:</td><td class="text-blue-500 font-bold text-base pl-2">${bestFaculty}</td></tr>
            `;
        }
    }

    // --- LOGIC CHART ---
    function renderChart(labels, dataObj) {
        const ctx = document.getElementById("facultyChart");
        if (!ctx) return;
        const dataValues = labels.map(code => {
            const f = dataObj[code] || { ai_positif: 0, total_aspek: 0 };
            return f.total_aspek > 0 ? Math.round((f.ai_positif / f.total_aspek) * 100) : 0;
        });

        new Chart(ctx, {
            type: "bar",
            data: {
                labels: labels,
                datasets: [{
                    label: "Kepuasan (%)",
                    data: dataValues,
                    backgroundColor: ["rgba(239, 68, 68, 0.7)", "rgba(234, 179, 8, 0.7)", "rgba(59, 130, 246, 0.7)", "rgba(20, 184, 166, 0.7)", "rgba(168, 85, 247, 0.7)"],
                    borderWidth: 0, borderRadius: 4, barPercentage: 0.6,
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, max: 100, grid: { color: "rgba(75, 85, 99, 0.1)" }, ticks: { color: "#9ca3af" } },
                    x: { grid: { display: false }, ticks: { color: "#d1d5db", font: { weight: "bold" } } }
                }
            }
        });
    }

    // --- LOGIC KARTU FAKULTAS (GRID RAPI) ---
    function renderFacultyCards(codes, data) {
        const container = document.getElementById("faculty-grid");
        let html = "";

        codes.forEach(code => {
            const stats = data[code] || { count: 0, ai_positif: 0, total_aspek: 0 };
            const percent = stats.total_aspek > 0 ? Math.round((stats.ai_positif / stats.total_aspek) * 100) : 0;
            
            let barClass = "bg-gray-700"; 
            if (stats.count > 0) {
                if (percent >= 70) barClass = "bg-green-500";
                else if (percent >= 40) barClass = "bg-yellow-500";
                else barClass = "bg-red-500";
            }

            html += `
            <div class="w-full">
                <div class="bg-[#0f1219] border border-gray-800 rounded-2xl p-5 h-full flex flex-col hover:border-gray-600 transition-colors duration-300 relative group">
                    <div class="flex justify-between items-start mb-4">
                        <h3 class="text-lg font-bold text-white tracking-wide">${code}</h3>
                        <div class="flex items-center gap-1 text-[10px] text-gray-400 bg-gray-900 px-2 py-1 rounded-md border border-gray-800">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                            <span>${stats.count} Feedback</span>
                        </div>
                    </div>
                    <p class="text-[9px] text-gray-500 uppercase tracking-wider font-semibold mb-1">KEPUASAN POSITIF</p>
                    <div class="flex items-baseline gap-1 mb-3"><span class="text-3xl font-bold text-white">${percent}%</span></div>
                    <div class="w-full bg-gray-800 rounded-full h-1.5 mb-5 overflow-hidden"><div class="${barClass} h-full rounded-full transition-all duration-1000" style="width: ${percent}%"></div></div>
                    <div class="mt-auto pt-4 border-t border-gray-800/50">
                        <a href="/fakultas/${code.toLowerCase()}" class="text-blue-500 text-xs font-bold hover:text-blue-400 transition flex items-center justify-between group-hover:translate-x-1 duration-300">
                            <span>Lihat detail...</span>
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </a>
                    </div>
                </div>
            </div>
            `;
        });
        if(container) container.innerHTML = html;
    }

    // --- LOGIC SUARA TERBARU (Baru & Mirip Index) ---
    function renderFeedbackList(feedbacks) {
        const container = document.getElementById("feedback-container");
        if (!container) return;

        if (feedbacks.length === 0) {
            container.innerHTML = `<div class="col-span-full text-center text-gray-500 italic py-8">Belum ada feedback terbaru.</div>`;
            return;
        }

        // Ambil 6 feedback terbaru saja agar halaman tidak kepanjangan (Opsional)
        const latestFeedbacks = feedbacks.slice(0, 9); 
        
        let html = "";
        latestFeedbacks.forEach(item => {
            // Format Tanggal
            const dateObj = new Date(item.tanggal_kirim);
            const displayDate = !isNaN(dateObj)
                ? dateObj.toLocaleDateString("id-ID", { day: "numeric", month: "short", year: "numeric" })
                : "-";

            // Style Role (Dosen vs Mahasiswa)
            const isDosen = item.kategori_user?.toLowerCase() === "dosen";
            const roleLabel = isDosen ? "Dosen" : "Mahasiswa";
            const roleColor = isDosen ? "bg-blue-900/40 text-blue-300" : "bg-gray-800 text-gray-400";
            const roleIcon = isDosen ? "👨‍🏫" : "🎓";
            
            // Warna Badge Fakultas
            const badgeColor = "bg-blue-500/10 text-blue-400 border border-blue-500/20";

            html += `
            <div class="bg-[#0f1219] border border-gray-800 rounded-2xl p-6 flex flex-col h-full hover:border-gray-600 transition-all duration-300 shadow-lg group">
                
                <div class="flex justify-between items-start mb-4">
                    <span class="px-2 py-1 ${badgeColor} text-[10px] font-bold uppercase rounded tracking-wider">
                        ${item.kode_fakultas}
                    </span>
                </div>
                
                <div class="flex-grow mb-6">
                    <div class="relative">
                        <span class="absolute -top-2 -left-1 text-2xl text-gray-700 opacity-50 font-serif">"</span>
                        <p class="text-gray-300 text-sm italic leading-relaxed pl-3 relative z-10">
                            ${item.komentar || "Tidak ada teks."}
                        </p>
                    </div>
                </div>

                <div class="mt-auto pt-4 border-t border-gray-800 flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full ${roleColor} flex items-center justify-center text-xs shadow-sm ring-1 ring-white/5">
                        ${roleIcon}
                    </div>
                    <div>
                        <p class="text-xs font-bold text-gray-200 uppercase tracking-wide">${roleLabel}</p>
                        <p class="text-[10px] text-gray-500">${displayDate}</p>
                    </div>
                </div>
            </div>
            `;
        });

        container.innerHTML = html;
    }

    // Jalankan
    initDashboard();
</script>
</Layout>
