---
import Layout from "../../layouts/Layout.astro";
import ThemeToggle from "../../components/ThemeToggle";

const API_URL = "https://nueljunt-backend-skripsi-nuel.hf.space";
---

<Layout title="Masuk Akun - UKRIM Feedback">
    <nav
        class="container mx-auto px-6 py-6 flex justify-between items-center relative z-20"
    >
        <div class="flex items-center gap-3">
            <div
                class="w-10 h-10 bg-white rounded-full flex items-center justify-center border-2 border-white shadow-sm overflow-hidden"
            >
                <img
                    src="/images/logo-ukrim.jpg"
                    alt="Logo UKRIM"
                    class="w-full h-full object-cover"
                />
            </div>
            <div
                class="text-xs font-bold leading-tight tracking-wider text-gray-700 dark:text-gray-200 uppercase"
            >
                Universitas<br />Kristen<br />Immanuel
            </div>
        </div>
        <div class="flex items-center gap-4">
            <ThemeToggle client:load />
            <a
                href="/"
                class="text-sm font-semibold text-gray-600 dark:text-gray-300 hover:text-blue-600 transition"
                >Beranda</a
            >
        </div>
    </nav>

    <main
        class="container mx-auto px-6 py-12 relative min-h-[80vh] flex items-center justify-center"
    >
        <div class="absolute inset-0 flex justify-center items-center -z-10">
            <div
                class="w-full max-w-lg h-96 bg-blue-500/20 dark:bg-blue-600/10 blur-[120px] rounded-full"
            >
            </div>
        </div>

        <div class="w-full max-w-md">
            <div
                class="bg-white dark:bg-[#111827] border border-gray-100 dark:border-gray-800 p-8 md:p-10 rounded-[2.5rem] shadow-2xl shadow-blue-500/5 transition-colors duration-300"
            >
                <div class="text-center mb-10">
                    <h1
                        class="text-3xl font-black text-gray-900 dark:text-white mb-3 tracking-tight"
                    >
                        SELAMAT <span class="text-blue-600">DATANG.</span>
                    </h1>
                    <p class="text-gray-500 dark:text-gray-400">
                        Masuk untuk memberikan feedback Anda.
                    </p>
                </div>

                <form id="loginForm" class="space-y-5">
                    <div>
                        <label
                            class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 px-1"
                            >Email Universitas</label
                        >
                        <input
                            type="email"
                            id="email"
                            class="w-full bg-gray-50 dark:bg-gray-900/50 border border-gray-200 dark:border-gray-800 rounded-2xl px-5 py-4 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all placeholder:text-gray-400"
                        />
                    </div>

                    <div>
                        <label
                            class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 px-1"
                            >Password</label
                        >
                        <input
                            type="password"
                            id="password"
                            class="w-full bg-gray-50 dark:bg-gray-900/50 border border-gray-200 dark:border-gray-800 rounded-2xl px-5 py-4 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all placeholder:text-gray-400"
                        />
                    </div>

                    <button
                        type="submit"
                        class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-2xl transition transform hover:-translate-y-1 shadow-lg shadow-blue-500/30 active:scale-95 mt-2"
                    >
                        Masuk Sekarang
                    </button>
                </form>

                <div
                    class="mt-8 p-4 bg-gray-50 dark:bg-gray-900/80 rounded-2xl border border-dashed border-gray-200 dark:border-gray-700"
                >
                    <div class="flex gap-3">
                        <span class="text-lg">💡</span>
                        <p
                            class="text-[11px] leading-relaxed text-gray-500 dark:text-gray-400 font-medium"
                        >
                            <strong class="text-bule-700 dark:text-blue-200"
                                >Lupa password?</strong
                            ><br />
                            Silakan hubungi bagian <span
                                class="text-blue-600 dark:text-blue-400 font-bold"
                                >Admin IT / Kantor Pusat</span
                            > dengan membawa KTM untuk verifikasi dan reset akun secara
                            manual.
                        </p>
                    </div>
                </div>

                <p
                    class="text-center text-gray-500 dark:text-gray-400 text-sm mt-8"
                >
                    Belum punya akun? <a
                        href="/auth/register"
                        class="text-blue-600 dark:text-blue-400 font-bold hover:underline"
                        >Daftar Sekarang</a
                    >
                </p>
            </div>
        </div>
    </main>
</Layout>

<script is:inline>
  const API_URL = "https://nueljunt-backend-skripsi-nuel.hf.space";
  const loginForm = document.getElementById("loginForm");

  loginForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    
    const email = document.getElementById("email").value;
    const password = document.getElementById("password").value;

    try {
      const response = await fetch("https://nueljunt-backend-skripsi-nuel.hf.space/auth/login", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, password }),
      });

      const result = await response.json();

      if (!response.ok) {
        alert("Gagal: " + (result.errors?.[0]?.message || "Email/Password salah"));
        return;
      }

      // Simpan Token
      const token = result.data.access_token;
      localStorage.setItem("access_token", token);

      const userRes = await fetch("https://nueljunt-backend-skripsi-nuel.hf.space/users/me", {
        method: "GET",
        headers: { 
          "Authorization": `Bearer ${token}`
        }
      });

      const userResult = await userRes.json();
      console.log("Data Profil Terdeteksi:", userResult.data); 

      if (userRes.ok && userResult.data) {
        const u = userResult.data;
        
        const namaTampil = u.nama_panggilan || u.first_name || email.split('@')[0];

        localStorage.setItem("user_profile", JSON.stringify({
          nama_panggilan: namaTampil
        }));

        alert("Login Berhasil! Halo, " + namaTampil);
        window.location.href = "/";
      }

    } catch (err) {
      console.error("Detail Error:", err);
      alert("Koneksi gagal. Pastikan Directus menyala di port 8055");
    }
  });
</script>
